# --- Vercel (production / preview builds) ---
# Your Railway service root URL (HTTPS, no trailing slash). Embedded at build time.
# VITE_EVENT_POSITIONS_API_BASE=https://xxxxxxxx.up.railway.app

# --- Local dev ---
# Leave VITE_EVENT_POSITIONS_API_BASE unset; use `npm run dev` so Vite proxies /api → :3040.

# --- Railway (API service) ---
# Optional: restrict browser origins (comma-separated). Default/no var = *
# CORS_ORIGIN=https://your-app.vercel.app,https://your-app-git-main-user.vercel.app
#
# Optional: persistent JSON on a Railway volume mount
# EVENT_POSITIONS_PATH=/data/event-positions.json
